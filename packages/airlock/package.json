{
  "name": "@airlock/airlock",
  "version": "0.1.0",
  "description": "Reversible redaction for calling any HTTP API on an untrusted provider without leaking PII or secrets. Umbrella package re-exporting @airlock/core and @airlock/fetch.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./src/core.ts",
      "import": "./dist/core.js"
    },
    "./fetch": {
      "types": "./src/fetch.ts",
      "import": "./dist/fetch.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@airlock/core": "^0.1.0",
    "@airlock/fetch": "^0.1.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsx": "^4.0.0",
    "@types/node": "^22.0.0"
  }
}
